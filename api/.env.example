# PostgreSQL bağlantısı (SQLAlchemy + psycopg2)
DATABASE_URL=postgresql+psycopg2://blog:blog@localhost:5432/blog

# JWT imza anahtarı — rastgele üret:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Admin (tek kullanıcı). Hash üret: python -m app.set_admin <şifre>
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# Yüklenen görsellerin dizini (üretimde kalıcı volume)
UPLOADS_DIR=./uploads

# CORS — yerel frontend kökeni (JSON liste)
CORS_ORIGINS=["http://localhost:3000"]
