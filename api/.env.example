# PostgreSQL bağlantısı (SQLAlchemy + psycopg2)
DATABASE_URL=postgresql+psycopg2://blog:blog@localhost:5432/blog

# JWT imza anahtarı — rastgele üret:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Admin (tek kullanıcı). Hash üret: python -m app.set_admin <şifre>
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# Yüklenen görsellerin dizini (üretimde kalıcı volume)
UPLOADS_DIR=./uploads

# CORS — yerel frontend kökeni (JSON liste)
CORS_ORIGINS=["http://localhost:3000"]

# --- İletişim formu (SMTP) ---
# Boş bırakılırsa form devre dışı kalır (503 döner). Gmail için:
#   2 Adımlı Doğrulama açık olmalı → Google Hesabı > Güvenlik > Uygulama şifreleri
#   ile 16 haneli bir şifre üret (boşlukları sil). SUNUCUDA $ içeren değerlerde $ -> $$ kaçır!
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=kondakci.k@gmail.com
SMTP_PASSWORD=
SMTP_STARTTLS=true
CONTACT_TO=kondakci.k@gmail.com
# CONTACT_FROM=   # boşsa SMTP_USER kullanılır
