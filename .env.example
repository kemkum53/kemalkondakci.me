# docker-compose tarafından okunur (değişken ikamesi için).
# Not: API sırları (JWT_SECRET, ADMIN_PASSWORD_HASH) api/.env içindedir.

# PostgreSQL kimlik bilgileri
POSTGRES_USER=blog
POSTGRES_PASSWORD=change-me
POSTGRES_DB=blog

# Frontend oturum imza anahtarı (en az 32 karakter):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
