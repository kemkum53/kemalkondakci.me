# iron-session imza anahtarı — en az 32 karakter, rastgele üret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=""

# Backend (FastAPI) adresi. Docker'da http://api:8000, yerelde http://localhost:8000
API_URL="http://localhost:8000"

# Oturum çerezini yalnızca HTTPS'te gönder. Production'da "true".
COOKIE_SECURE="false"
